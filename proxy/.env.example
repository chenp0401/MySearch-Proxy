ADMIN_PASSWORD=change-me
SOCIAL_GATEWAY_UPSTREAM_BASE_URL=https://api.x.ai/v1
SOCIAL_GATEWAY_UPSTREAM_RESPONSES_PATH=/responses

# 推荐：如果上游是 grok2api，直接填后台地址和 app_key。
# proxy 会自动从 /v1/admin/config 继承 app.api_key，
# 再从 /v1/admin/tokens 拉 token 状态和剩余额度。
SOCIAL_GATEWAY_ADMIN_BASE_URL=https://media.example.com
SOCIAL_GATEWAY_ADMIN_APP_KEY=
SOCIAL_GATEWAY_ADMIN_VERIFY_PATH=/v1/admin/verify
SOCIAL_GATEWAY_ADMIN_CONFIG_PATH=/v1/admin/config
SOCIAL_GATEWAY_ADMIN_TOKENS_PATH=/v1/admin/tokens
SOCIAL_GATEWAY_CACHE_TTL_SECONDS=60

# 可选手动覆写：
# 1. SOCIAL_GATEWAY_UPSTREAM_API_KEY：真正转发到 /responses 时用哪个 key
# 2. SOCIAL_GATEWAY_TOKEN：要求客户端调用 /social/search 时携带哪个 token
# 如果两项都不填，但 admin 模式能读到 app.api_key，就会自动复用它。
SOCIAL_GATEWAY_UPSTREAM_API_KEY=
SOCIAL_GATEWAY_MODEL=grok-4.1-fast
SOCIAL_GATEWAY_TOKEN=

# Qwen / DashScope 备援（私有 fork 扩展）
# QWEN_API_BASE：DashScope 上游地址，一般无需改动；如走代理可指向中转。
# QWEN_FALLBACK_ENABLED：默认 true。当 Tavily key 池全部失效或耗尽时，
#   /api/search 会自动转发到 Qwen 后端，并在响应头加 X-Provider: qwen。
#   设为 false 可一键关闭 fallback，恢复上游"池空 → 503"行为。
# 通义 key 通过控制台 /api/keys?service=qwen 注入；DashScope 不提供官方
# usage 接口，控制台对 qwen 卡片显示"实时额度暂时无法查询"。
QWEN_API_BASE=https://dashscope.aliyuncs.com
QWEN_FALLBACK_ENABLED=true
