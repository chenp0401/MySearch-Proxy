# =============================================================================
# MySearch-Proxy 生产环境 .env 模板（东京 LH 部署）
#
# 用法：
#   1) cp .env.production.example .env
#   2) 把所有 change-me / 占位符替换为真实值
#   3) chmod 600 .env
#   4) docker compose up -d
#
# 不要把 .env 提交到 git；只有这份 .env.production.example 进仓库。
# =============================================================================

# --- 控制台访问 ---------------------------------------------------------------
# 控制台 /admin 登录密码。建议 24 位以上随机串。
ADMIN_PASSWORD=change-me-please-use-long-random-string

# --- Social Gateway（grok2api 等上游，走 /social/search 时才用）-----------------
SOCIAL_GATEWAY_UPSTREAM_BASE_URL=https://api.x.ai/v1
SOCIAL_GATEWAY_UPSTREAM_RESPONSES_PATH=/responses

# 如果上游是 grok2api，填后台地址 + app_key，proxy 会自动从 /v1/admin/config
# 拉 app.api_key、再从 /v1/admin/tokens 拉 token 状态和剩余额度。留空则禁用。
SOCIAL_GATEWAY_ADMIN_BASE_URL=
SOCIAL_GATEWAY_ADMIN_APP_KEY=
SOCIAL_GATEWAY_ADMIN_VERIFY_PATH=/v1/admin/verify
SOCIAL_GATEWAY_ADMIN_CONFIG_PATH=/v1/admin/config
SOCIAL_GATEWAY_ADMIN_TOKENS_PATH=/v1/admin/tokens
SOCIAL_GATEWAY_CACHE_TTL_SECONDS=60

# 可选手动覆写：
SOCIAL_GATEWAY_UPSTREAM_API_KEY=
SOCIAL_GATEWAY_MODEL=grok-4.1-fast
SOCIAL_GATEWAY_TOKEN=

# --- Qwen / DashScope fallback（私有 fork 扩展）---------------------------------
# 当 Tavily key 池全部失效时，/api/search 自动转发到 Qwen，并在响应头加
# X-Provider: qwen。设为 false 可一键关闭，恢复"池空 -> 503"。
# Qwen key 通过控制台 /api/keys?service=qwen 注入。
QWEN_API_BASE=https://dashscope.aliyuncs.com
QWEN_FALLBACK_ENABLED=true

# --- SearXNG fallback（/search 链末端兜底）-------------------------------------
# 当 Tavily 池空 + Qwen 不可用/失败时，/search 自动调用本地 SearXNG，
# 响应头打 X-Provider: searxng。完全免费、自托管，最后保险。
# 留空则禁用。东京 LH 同机部署时填 docker bridge 网关地址：
SEARXNG_BASE_URL=http://172.17.0.1:8080
SEARXNG_TIMEOUT_SECONDS=15

# --- 本地 extract fallback（/extract 兜底）------------------------------------
# Tavily extract 池空时，proxy 用容器内置的 httpx + markdownify 自己抓页面，
# 输出 Tavily 兼容 schema，响应头打 X-Provider: local-extract。
# 仅做轻量 HTTP fetch，不做反反爬；如果需要绕 Cloudflare 等强反爬，
# 请在 OpenClaw / Hermes 那一层单独挂 Scrapling MCP（独立部署，不走本 proxy）。
LOCAL_EXTRACT_FALLBACK_ENABLED=true
LOCAL_EXTRACT_TIMEOUT_SECONDS=30
LOCAL_EXTRACT_MAX_URLS=5
# 旧名兼容（同名变量已支持）：SCRAPLING_FALLBACK_ENABLED / SCRAPLING_TIMEOUT_SECONDS / SCRAPLING_MAX_URLS
